---
import Base from '../../layouts/Base.astro';
import { todasParejas, categoriaInfo, rangoReal, precio, motor } from '../../lib/ebikes.js';

export function getStaticPaths() {
  return todasParejas().map(([a, b]) => ({
    params: { combo: `${a.slug}-vs-${b.slug}` },
    props: { a, b },
  }));
}

const { a, b } = Astro.props;
const cat = categoriaInfo(a.categoria);

function ganador() {
  const ra = a.autonomia_real_max_km ?? -1;
  const rb = b.autonomia_real_max_km ?? -1;
  if (ra === rb) return null;
  return ra > rb ? a : b;
}
const mejor = ganador();
const filas = [
  ['Batería', `${a.bateria_wh} Wh`, `${b.bateria_wh} Wh`],
  ['Peso', `${a.peso_kg} kg`, `${b.peso_kg} kg`],
  ['Motor', motor(a), motor(b)],
  ['Catálogo', `${a.autonomia_catalogo_km} km`, `${b.autonomia_catalogo_km} km`],
  ['Autonomía real', rangoReal(a), rangoReal(b)],
  ['Precio', precio(a), precio(b)],
];
---

<Base
  title={`${a.nombre} vs ${b.nombre}`}
  descripcion={`Comparativa de autonomía real entre ${a.nombre} y ${b.nombre}: batería, peso, precio y km de verdad.`}
>
  <p><a href={`/${a.categoria}`}>← {cat.nombre}</a></p>
  <h1>{a.nombre} vs {b.nombre}</h1>
  <p class="subtitulo">¿Cuál aguanta más de verdad?</p>

  {mejor && (
    <div class="aviso" style="background: var(--acento-bg); color: var(--acento)">
      Por autonomía real reportada, gana la <strong>{mejor.nombre}</strong>.
    </div>
  )}

  <table class="datos">
    <thead>
      <tr><th></th><th>{a.nombre}</th><th>{b.nombre}</th></tr>
    </thead>
    <tbody>
      {filas.map(([etq, va, vb]) => (
        <tr>
          <th>{etq}</th>
          <td class={etq === 'Autonomía real' ? 'real' : ''}>{va}</td>
          <td class={etq === 'Autonomía real' ? 'real' : ''}>{vb}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <div class="grid-vs" style="margin-top: 24px;">
    <p><a class="cta" href={a.afiliado_url} rel="sponsored nofollow noopener" target="_blank">Ver {a.nombre} →</a></p>
    <p><a class="cta" href={b.afiliado_url} rel="sponsored nofollow noopener" target="_blank">Ver {b.nombre} →</a></p>
  </div>

  <p class="fuentes" style="margin-top: 20px;">
    Fichas completas con fuentes: <a href={`/ficha/${a.slug}`}>{a.nombre}</a> · <a href={`/ficha/${b.slug}`}>{b.nombre}</a>
  </p>
</Base>
