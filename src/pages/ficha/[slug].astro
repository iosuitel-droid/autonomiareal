---
import Base from '../../layouts/Base.astro';
import BarraAutonomia from '../../components/BarraAutonomia.astro';
import { productos, categoriaInfo, rangoReal, porcentajeCumplido, precio, motor } from '../../lib/ebikes.js';

export function getStaticPaths() {
  return productos.map((p) => ({ params: { slug: p.slug }, props: { p } }));
}

const { p } = Astro.props;
const cat = categoriaInfo(p.categoria);
const pct = porcentajeCumplido(p);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: p.nombre,
  brand: { '@type': 'Brand', name: p.marca },
  category: cat.nombre,
  url: `https://autonomiareal.com/ficha/${p.slug}`,
  additionalProperty: [
    { '@type': 'PropertyValue', name: 'Autonomía real estimada', value: rangoReal(p) },
    { '@type': 'PropertyValue', name: 'Autonomía de catálogo', value: `${p.autonomia_catalogo_km} km` },
    { '@type': 'PropertyValue', name: 'Batería', value: `${p.bateria_wh} Wh` },
    { '@type': 'PropertyValue', name: 'Peso', value: `${p.peso_kg} kg` },
  ],
  ...(p.afiliado_url !== '#'
    ? {
        offers: {
          '@type': 'Offer',
          price: p.precio_eur,
          priceCurrency: 'EUR',
          availability: 'https://schema.org/InStock',
          url: `https://autonomiareal.com/ficha/${p.slug}`,
        },
      }
    : {}),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />


<Base
  title={`${p.nombre}: autonomía real`}
  descripcion={`Autonomía real de ${p.nombre} según reseñas y propietarios, frente a los ${p.autonomia_catalogo_km} km del catálogo.`}
>
  <p><a href={`/${p.categoria}`}>← {cat.nombre}</a></p>
  <h1>{p.nombre}</h1>
  <p class="subtitulo">{p.marca} · {precio(p)}</p>

  {p.imagen && <img src={p.imagen} alt={p.nombre} loading="lazy" class="prod-img" />}

  <BarraAutonomia p={p} />
  <p class="fuentes">Dato real: {p.calidad_dato}</p>

  <h2>Ficha técnica</h2>
  <table class="datos">
    <tbody>
      <tr><th>Batería</th><td>{p.bateria_wh} Wh</td></tr>
      <tr><th>Peso</th><td>{p.peso_kg} kg</td></tr>
      <tr><th>Motor</th><td>{motor(p)}</td></tr>
      <tr><th>Autonomía catálogo</th><td>{p.autonomia_catalogo_km} km</td></tr>
      <tr><th>Autonomía real</th><td class={p.autonomia_real_max_km == null ? 'sindato' : 'real'}>{rangoReal(p)}</td></tr>
      <tr><th>Precio aprox.</th><td>{precio(p)}</td></tr>
    </tbody>
  </table>

  {p.notas && <div class="aviso">{p.notas}</div>}

  <p style="margin: 24px 0;">
    {p.afiliado_url === '#' ? (
      <span class="fuentes">Sin tienda con programa de afiliados para este modelo.</span>
    ) : (
      <a class="cta" href={p.afiliado_url} rel="sponsored nofollow noopener" target="_blank">Ver en {p.tienda} →</a>
    )}
  </p>

  <h2>Fuentes</h2>
  <ul class="fuentes">
    {p.fuentes.map((u) => (
      <li><a href={u} rel="nofollow noopener" target="_blank">{u}</a></li>
    ))}
  </ul>
</Base>
