---
import { realMedia, rangoReal } from '../lib/ebikes.js';
const { p } = Astro.props;
const media = realMedia(p);
const pct = media != null && p.autonomia_catalogo_km ? Math.min(100, Math.round((media / p.autonomia_catalogo_km) * 100)) : null;
---

<div class="gap">
  <div class="gap-row">
    <span class="gap-lab">Real</span>
    <div class="gap-track"><div class="gap-fill" style={`width:${pct ?? 0}%`}></div></div>
    <span class="gap-val">{rangoReal(p)}</span>
  </div>
  <div class="gap-row">
    <span class="gap-lab">Catálogo</span>
    <div class="gap-track"><div class="gap-fill gap-cat" style="width:100%"></div></div>
    <span class="gap-val">{p.autonomia_catalogo_km} km</span>
  </div>
  {pct != null && <p class="gap-pct">En la práctica cumple el <strong>{pct}%</strong> de lo que promete el catálogo.</p>}
  {pct == null && <p class="gap-pct gap-na">Sin datos reales verificables todavía para este modelo.</p>}
</div>

<style>
  .gap { background: var(--tarjeta); border: 1px solid var(--linea); border-radius: 12px; padding: 20px 22px; margin: 18px 0; }
  .gap-row { display: flex; align-items: center; gap: 14px; margin-bottom: 12px; }
  .gap-lab { min-width: 72px; font-size: 14px; color: var(--tinta-suave); }
  .gap-track { flex: 1; height: 22px; background: #eef1f0; border-radius: 6px; overflow: hidden; }
  .gap-fill { height: 100%; background: var(--acento); border-radius: 6px; }
  .gap-fill.gap-cat { background: #c7cecb; }
  .gap-val { min-width: 88px; text-align: right; font-weight: 600; font-size: 15px; }
  .gap-pct { margin: 6px 0 0; font-size: 14px; color: var(--tinta-suave); }
  .gap-pct strong { color: var(--acento); }
  .gap-na { color: var(--aviso); }
</style>
